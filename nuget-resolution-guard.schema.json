{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/nuget-resolution-guard.schema.json",
  "title": "ResolutionGuard.NuGet config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["off", "info", "warning", "error"]
    },
    "scope": {
      "type": "string",
      "enum": ["repository", "solution"]
    },
    "directOnly": {
      "type": "boolean"
    },
    "runtimeOnly": {
      "type": "boolean"
    },
    "excludeEntrypoints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "excludePackageIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "packageId": {
            "type": "string",
            "minLength": 1
          },
          "mode": {
            "type": "string",
            "enum": ["off", "info", "warning", "error"]
          },
          "versions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          }
        },
        "required": ["packageId", "mode"]
      }
    }
  }
}
